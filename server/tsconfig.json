{
  "compilerOptions": {
    "target": "es2022",
    "module": "node16",
    "moduleResolution": "node16",
    "types": ["node"],

    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,

    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "constants/*": ["./src/constants/*"],
      "controllers/*": ["./src/controllers/*"],
      "db/*": ["./src/db/*"],
      "middlewares/*": ["./src/middlewares/*"],
      "routes/*": ["./src/routes/*"],
      "utils/*": ["./src/utils/*"]
    }
  }
}
